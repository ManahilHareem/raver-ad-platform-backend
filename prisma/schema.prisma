generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model AISession {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @db.Uuid
  sessionId   String   @unique
  campaignId  String?
  tag         String?
  type        String
  metadata    Json?
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  User        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Agent {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid
  name      String
  type      String?
  status    String   @default("idle")
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Asset {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String    @db.Uuid
  campaignId String?   @db.Uuid
  type       String
  url        String
  fileSize   Int?
  createdAt  DateTime  @default(now()) @db.Timestamptz(6)
  Campaign   Campaign? @relation(fields: [campaignId], references: [id])
  User       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Billing {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String    @unique @db.Uuid
  stripeCustomerId String?
  planTier         String    @default("free")
  status           String    @default("active")
  currentPeriodEnd DateTime? @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @db.Timestamptz(6)
  User             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Campaign {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String            @db.Uuid
  name            String
  status          String            @default("draft")
  budget          Int               @default(0)
  startDate       DateTime?         @db.Timestamptz(6)
  endDate         DateTime?         @db.Timestamptz(6)
  config          Json?
  createdAt       DateTime          @default(now()) @db.Timestamptz(6)
  projectId       String?           @db.Uuid
  audience        String?
  colorScheme     String?
  duration        String?
  format          String?
  objective       String?
  platforms       String[]
  tones           String[]
  visualStyles    String[]
  Asset           Asset[]
  Project         Project?          @relation(fields: [projectId], references: [id])
  User            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  ImageLeadResult ImageLeadResult[]
  metrics         Metric[]
}

model ImageLeadResult {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String    @db.Uuid
  sessionId    String    @unique
  campaignId   String?   @db.Uuid
  mainImageUrl String?
  scenes       Json?
  metadata     Json?
  createdAt    DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime  @default(now()) @db.Timestamptz(6)
  Campaign     Campaign? @relation(fields: [campaignId], references: [id])
  User         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Metric {
  id          BigInt   @id @default(autoincrement())
  campaignId  String   @db.Uuid
  impressions Int      @default(0)
  clicks      Int      @default(0)
  spend       Decimal  @default(0.00) @db.Decimal(12, 2)
  recordedAt  DateTime @default(now()) @db.Timestamptz(6)
  Campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model PaymentMethod {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String   @db.Uuid
  cardHolderName String
  cardNumber     String
  expiryDate     String
  cvv            String?
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now()) @db.Timestamptz(6)
  User           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Project {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String     @db.Uuid
  name        String
  description String?
  status      String     @default("active")
  createdAt   DateTime   @default(now()) @db.Timestamptz(6)
  campaigns   Campaign[]
  User        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Template {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  category  String?
  data      Json?
  isPublic  Boolean  @default(false)
  createdAt DateTime @default(now()) @db.Timestamptz(6)
}

model User {
  id                String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email             String            @unique
  fullName          String?
  avatarUrl         String?
  createdAt         DateTime          @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime          @default(now()) @db.Timestamptz(6)
  password          String?
  bio               String?
  facebook          String?
  instagram         String?
  linkedin          String?
  professionalRole  String?
  twitter           String?
  website           String?
  aiInsights        Boolean           @default(true)
  campaignUpdates   Boolean           @default(true)
  teamActivity      Boolean           @default(true)
  weeklySummary     Boolean           @default(true)
  aiSessions        AISession[]
  agents            Agent[]
  assets            Asset[]
  Billing           Billing?
  campaigns         Campaign[]
  imageLeadResults  ImageLeadResult[]
  producerResults   ProducerResult[]
  audioLeadResults  AudioLeadResult[]
  copyLeadResults   CopyLeadResult[]
  editorResults     EditorResult[]
  paymentMethods    PaymentMethod[]
  projects          Project[]
}

model ProducerResult {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String   @db.Uuid
  sessionId    String?
  campaignId   String   @unique
  brief        Json?
  status       String?
  result       Json?
  createdAt    DateTime @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @db.Timestamptz(6)
  User         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AudioLeadResult {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String   @db.Uuid
  sessionId    String?
  musicUrl     String?
  voiceoverUrl String?
  mixUrl       String?
  metadata     Json?
  createdAt    DateTime @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @db.Timestamptz(6)
  User         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CopyLeadResult {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String   @db.Uuid
  sessionId    String?
  script       Json?
  captions     Json?
  overlays     Json?
  cta          Json?
  hashtags     Json?
  metadata     Json?
  createdAt    DateTime @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @db.Timestamptz(6)
  User         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EditorResult {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String   @db.Uuid
  sessionId    String?
  videoUrl     String?
  format       String?
  metadata     Json?
  createdAt    DateTime @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @db.Timestamptz(6)
  User         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
