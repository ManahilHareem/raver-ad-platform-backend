generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email            String          @unique
  fullName         String?
  avatarUrl        String?
  createdAt        DateTime        @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime        @default(now()) @db.Timestamptz(6)
  password         String?
  bio              String?
  facebook         String?
  instagram        String?
  linkedin         String?
  professionalRole String?
  twitter          String?
  website          String?
  aiInsights       Boolean         @default(true)
  campaignUpdates  Boolean         @default(true)
  teamActivity     Boolean         @default(true)
  weeklySummary    Boolean         @default(true)
  agents           Agent[]
  assets           Asset[]
  billing          Billing?
  campaigns        Campaign[]
  paymentMethods   PaymentMethod[]
  projects         Project[]
  aiSessions       AISession[]
}

model AISession {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid
  sessionId String   @unique
  tag       String?
  type      String   // "chat", "editor", "ads", etc.
  metadata  Json?
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PaymentMethod {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String   @db.Uuid
  cardHolderName String
  cardNumber     String
  expiryDate     String
  cvv            String?
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now()) @db.Timestamptz(6)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Billing {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String    @unique @db.Uuid
  stripeCustomerId String?
  planTier         String    @default("free")
  status           String    @default("active")
  currentPeriodEnd DateTime? @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @db.Timestamptz(6)
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Project {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String     @db.Uuid
  name        String
  description String?
  status      String     @default("active")
  createdAt   DateTime   @default(now()) @db.Timestamptz(6)
  campaigns   Campaign[]
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Campaign {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String    @db.Uuid
  name         String
  status       String    @default("draft")
  budget       Int       @default(0)
  startDate    DateTime? @db.Timestamptz(6)
  endDate      DateTime? @db.Timestamptz(6)
  config       Json?
  createdAt    DateTime  @default(now()) @db.Timestamptz(6)
  projectId    String?   @db.Uuid
  audience     String?
  colorScheme  String?
  duration     String?
  format       String?
  objective    String?
  platforms    String[]
  tones        String[]
  visualStyles String[]
  assets       Asset[]
  project      Project?  @relation(fields: [projectId], references: [id])
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  metrics      Metric[]
}

model Asset {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String    @db.Uuid
  campaignId String?   @db.Uuid
  type       String
  url        String
  fileSize   Int?
  createdAt  DateTime  @default(now()) @db.Timestamptz(6)
  campaign   Campaign? @relation(fields: [campaignId], references: [id])
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Template {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  category  String?
  data      Json?
  isPublic  Boolean  @default(false)
  createdAt DateTime @default(now()) @db.Timestamptz(6)
}

model Agent {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid
  name      String
  type      String?
  status    String   @default("idle")
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Metric {
  id          BigInt   @id @default(autoincrement())
  campaignId  String   @db.Uuid
  impressions Int      @default(0)
  clicks      Int      @default(0)
  spend       Decimal  @default(0.00) @db.Decimal(12, 2)
  recordedAt  DateTime @default(now()) @db.Timestamptz(6)
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}
